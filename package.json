{
  "name": "minimalcms",
  "version": "0.0.4",
  "description": "MinimalCMS build tools",
  "private": true,
  "scripts": {
    "scss:admin": "sass mc-admin/assets/src/scss/admin.scss mc-admin/assets/css/admin.css --style=expanded --no-source-map",
    "scss:theme": "sass mc-content/themes/default/src/scss/style.scss mc-content/themes/default/style.css --style=expanded --no-source-map",
    "scss:admin:min": "sass mc-admin/assets/src/scss/admin.scss mc-admin/assets/css/admin.min.css --style=compressed --no-source-map",
    "scss:theme:min": "sass mc-content/themes/default/src/scss/style.scss mc-content/themes/default/style.min.css --style=compressed --no-source-map",
    "vendor:copy": "node mc-includes/scripts/vendor-copy.js",
    "build": "npm run vendor:copy && npm run scss:admin && npm run scss:theme && npm run scss:admin:min && npm run scss:theme:min",
    "watch": "sass --watch mc-admin/assets/src/scss/admin.scss:mc-admin/assets/css/admin.css mc-content/themes/default/src/scss/style.scss:mc-content/themes/default/style.css --style=expanded --no-source-map",
    "version": "node scripts/update-version.js"
  },
  "dependencies": {
    "easymde": "^2.20.0"
  },
  "devDependencies": {
    "sass": "^1.97.3"
  }
}
